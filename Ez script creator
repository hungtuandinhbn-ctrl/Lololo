<body>

<div class="header">
  <h1>Tạo BloxFruit của riêng bạn một cách dễ dàng và nhanh chóng</h1>
  <p>Tạo web script miễn phí không cần phải vượt qua link nhanh hơn</p>
</div>

<div class="card">
  <div class="section-label">Cài Đặt</div>
  <div class="field">
    <label>Khóa API ImgBB (Khóa API ImgBB)</label>
    <input type="text" id="apiKey" placeholder="Để trống để sử dụng API có sẵn...">
    <div class="note">
      Dán API Key vào đây hoặc bỏ qua nếu muốn sử dụng API có sẵn.<br>
      Nếu muốn sử dụng khóa riêng: <a href="https://api.imgbb.com/" target="_blank">Lấy tại đây</a>
    </div>
  </div>
  <div class="field">
    <label>Tiêu đề Script (Tiêu đề tập lệnh)</label>
    <input type="text" id="scriptTitle" placeholder="Ví dụ: Blox Fruits Hub">
  </div>
  <div class="field">
    <label>Phụ đề Script (Tiêu đề phụ của script)</label>
    <input type="text" id="scriptSub" placeholder="Ví dụ: V1.0.0 - Khóa bản quyền miễn phí">
  </div>
  <div class="field">
    <label>Hình Ảnh Script (Upload lên ImgBB)</label>
    <div class="upload-row">
      <div class="img-preview" id="imgPreviewBox">
        <img id="imgPreviewEl" src="https://lambloxfruitscript.vercel.app/" alt="">
        <span id="imgPreviewText">Chưa có ảnh</span>
        <div class="spinner-wrap" id="spinnerWrap"><div class="spinner"></div></div>
      </div>
      <div class="upload-right">
        <button class="btn-upload">Chọn tệp</button>
        <input type="file" id="fileInput" accept="image/png,image/jpeg,image/gif,image/webp" style="display:none">
        <div class="upload-status">
          <div id="uploadFname" style="color:var(--text)">Không có tệp nào được chọn</div>
          <div class="hint">Hỗ trợ PNG, JPG. Tự động tải lên và tạo URL trực tiếp.</div>
        </div>
        <div class="upload-progress" id="uploadProgress">
          <div class="upload-progress-bar" id="uploadProgressBar"></div>
        </div>
        <div class="upload-url" id="uploadUrl"></div>
      </div>
    </div>
  </div>
  <div class="row2">
    <div class="field">
      <label>Tên Tác Giả (Author Name)</label>
      <input type="text" id="authorName" placeholder="Ví dụ: Scripter123">
    </div>
    <div class="field">
      <label>Phụ Đề Tác Giả (Tiêu đề phụ của tác giả)</label>
      <input type="text" id="authorSub" placeholder="Ví dụ: Discord: @xyz">
    </div>
  </div>
</div>

<div class="card">
  <div class="preview-label">Xem Trước Giao Diện (Fluent UI)</div>
  <div class="fluent-win">
    <div class="f-titlebar">
      <div class="f-titlebar-left">
        <div class="f-avatar" id="fAvatar">AC</div>
        <div>
          <div class="f-wintitle" id="fWinTitle">Tên của bạn</div>
          <div class="f-winsub" id="fWinSub">Đăng ký và thích</div>
        </div>
      </div>
      <div class="f-winbtns">
        <button class="f-winbtn min"></button>
        <button class="f-winbtn max"></button>
        <button class="f-winbtn cls"></button>
      </div>
    </div>
    <div class="f-body">
      <div class="f-sidebar">
        <div class="f-search">Tìm một cái gì đó</div>
        <div class="f-nav-item"><span class="f-dot" style="background:var(--red)"></span>Tab Cửa hàng</div>
        <div class="f-nav-item active"><span class="f-dot" style="background:var(--teal)"></span>Tab Cấu hình Trang trại</div>
        <div class="f-nav-item"><span class="f-dot" style="background:var(--green)"></span>Tab Nông nghiệp</div>
        <div class="f-nav-item"><span class="f-dot" style="background:var(--yellow)"></span>Tab mục</div>
      </div>
      <div class="f-content">
        <div class="f-tab-title">Tab Cấu hình Trang trại</div>
        <div class="f-row">
          <div>
            <div class="f-row-label">Xe buýt tự động</div>
            <div class="f-row-sub">Tự động thám hiểm trang thái</div>
          </div>
          <div class="f-toggle"></div>
        </div>
        <div class="f-row">
          <div>
            <div class="f-row-label">Chọn công cụ</div>
            <div class="f-row-sub">Chọn công cụ yêu thích</div>
          </div>
          <select class="f-select">
            <option>Cân chiến</option>
            <option>Kiếm</option>
            <option>Súng</option>
          </select>
        </div>
        <div class="f-row">
          <div>
            <div class="f-row-label">Tự động cấp độ trang trại</div>
            <div class="f-row-sub">Bắt đầu tiêu diệt quái vật</div>
          </div>
          <div class="f-toggle off"></div>
        </div>
      </div>
    </div>
  </div>
  <div class="fluent-caption">* Phong cách mô phỏng giao diện Fluent UI</div>
</div>

<div class="script-card">
  <div class="script-header">
    <span class="script-filename">script.lua</span>
    <button class="btn-copy" id="copyBtn">Sao Chép</button>
  </div>
  <div class="script-body">
<span class="c-comment">-- this script created at https://lambloxfruitscript.vercel.app/</span><br>
<span class="c-func">getgenv</span>().<span class="c-func">ScriptTitle</span> = <span class="c-str" id="o-title">"Script Title"</span><br>
<span class="c-func">getgenv</span>().<span class="c-func">ScriptSubTitle</span> = <span class="c-str" id="o-sub">"Script Sub Title"</span><br>
<span class="c-func">getgenv</span>().<span class="c-func">ScriptImage</span> = <span class="c-str" id="o-img">"IMAGE_URL_HERE"</span><br>
<span class="c-func">getgenv</span>().<span class="c-func">ScriptAuthorName</span> = <span class="c-str" id="o-author">"Author Name"</span><br>
<span class="c-func">getgenv</span>().<span class="c-func">ScriptAuthorSubTitle</span> = <span class="c-str" id="o-authorsub">"Author Info"</span><br>
<span class="c-load">loadstring</span>(<span class="c-func">game</span>:<span class="c-func">HttpGet</span>(<span class="c-str">"https://raw.githubusercontent.com/hoannhatz/Script/refs/heads/main/EZScript.lua"</span>))()
  </div>
</div>

<div class="toast" id="toast">✓ Đã sao chép vào clipboard!</div>
<canvas id="lixiCanvas" width="384" height="713"></canvas>




</body></html>
